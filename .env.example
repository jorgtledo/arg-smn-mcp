# No se requieren credenciales para la API del SMN — es pública.

# Modo de transporte MCP:
#   http  (predeterminado) — servidor HTTP/SSE; requiere PORT y API_KEY.
#                            Usar con Docker Compose, n8n o acceso remoto.
#   stdio                  — comunicación por stdin/stdout; sin puerto de red
#                            ni API_KEY. Usar cuando el cliente MCP lanza el
#                            contenedor directamente (docker run -i).
MCP_TRANSPORT=http

# Puerto del servidor HTTP (solo se usa cuando MCP_TRANSPORT=http).
PORT=3000

# Clave de API para autenticar las conexiones al servidor MCP.
# Solo se usa cuando MCP_TRANSPORT=http.
# Si no se define, se genera una aleatoria en cada inicio (ver registros).
API_KEY=cambia-esta-clave-por-una-segura

# Nivel de registro: INFO (valor predeterminado) | DEBUG
# DEBUG agrega el endpoint HTTP exacto invocado al SMN y su código de respuesta.
LOG_LEVEL=INFO
NODE_ENV=production
