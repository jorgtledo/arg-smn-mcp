{
  "name": "arg-smn-mcp",
  "version": "1.0.1",
  "description": "Servidor MCP para la API del Servicio Meteorológico Nacional Argentino",
  "author": "Jorge Toledo",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
